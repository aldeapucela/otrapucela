<!doctype html>
<html lang="es">
  <head>
    {% set resolvedCanonicalUrl = (canonicalUrl or page.url) | absoluteUrl(site.siteUrl) %}
    {% set resolvedOgImage = (ogImage or site.defaultSocialImage) | absoluteUrl(site.siteUrl) %}
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title or "La Otra Pucela" }}</title>
    <meta name="description" content="{{ description or 'Medio digital estático con artículos publicados desde Discourse.' }}">
    <meta name="theme-color" content="#1F2937" media="(prefers-color-scheme: light)">
    <meta name="theme-color" content="#1a2529" media="(prefers-color-scheme: dark)">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-title" content="La Otra Pucela">
    <link rel="canonical" href="{{ resolvedCanonicalUrl }}">
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="shortcut icon" href="/favicon.ico">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/manifest.webmanifest">

    <meta property="og:type" content="{{ ogType or 'website' }}">
    <meta property="og:site_name" content="La Otra Pucela">
    <meta property="og:title" content="{{ ogTitle or title or 'La Otra Pucela' }}">
    <meta property="og:description" content="{{ ogDescription or description or 'Medio digital estático con artículos publicados desde Discourse.' }}">
    <meta property="og:url" content="{{ resolvedCanonicalUrl }}">
    <meta property="og:image" content="{{ resolvedOgImage }}">

    <meta name="twitter:card" content="{{ twitterCard or 'summary_large_image' }}">
    <meta name="twitter:title" content="{{ twitterTitle or ogTitle or title or 'La Otra Pucela' }}">
    <meta name="twitter:description" content="{{ twitterDescription or ogDescription or description or 'Medio digital estático con artículos publicados desde Discourse.' }}">
    <meta name="twitter:image" content="{{ resolvedOgImage }}">

    <link rel="alternate" type="application/rss+xml" title="{{ site.name }} RSS" href="{{ site.feedPath }}">
    <link rel="alternate" type="application/rss+xml" title="{{ site.podcast.title }} Podcast" href="{{ site.podcastPath }}">
    <link rel="stylesheet" href="{{ assetManifest['assets/styles/main.css'] or '/assets/styles/main.css' }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600&display=swap"
    >
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    >
    <script src="/assets/js/matomo.js" defer></script>
    <script>
      // Prevent FOUC by setting dark mode early
      if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
  </head>
  <body class="min-h-screen {{ bodyClass or 'bg-gray-50 dark:bg-[#151c21]' }} dark:bg-[#151c21] dark:text-gray-200 text-gray-800 dark:text-gray-200 antialiased transition-colors duration-200">
    <div class="relative min-h-screen">
      <header
        id="js-header"
        class="relative sticky top-0 z-50 border-b border-gray-200 dark:border-gray-800 bg-white dark:bg-[#1a2529] transition-transform duration-300 shadow-sm"
      >
        <div class="relative mx-auto flex min-h-16 max-w-6xl items-center justify-between gap-4 px-4 py-4 sm:justify-center sm:px-6 lg:px-8">
          <a href="/" class="min-w-0 flex-1 pr-24 text-left text-[#092440] dark:text-gray-100 sm:flex-none sm:pr-0 sm:text-center {% if page.url == '/' %}lg:hidden{% endif %}">
            <span class="block font-serif text-[1.2rem] uppercase tracking-[0.02em] sm:text-[1.35rem]">
              <span class="font-['Montserrat',sans-serif] font-medium">La Otra</span>
              <span class="font-extrabold [font-variation-settings:'wght'_850]">Pucela</span>
            </span>
          </a>

          <div class="absolute right-2 flex items-center gap-0 sm:right-4 lg:right-6">
            <a href="/boletin/" class="inline-flex min-h-11 items-center gap-1 rounded-full px-0.5 text-gray-500 dark:text-gray-400 sm:hidden" aria-label="Ir al boletín" data-newsletter-header-link data-newsletter-cta>
              <i class="fa-regular fa-envelope text-base" aria-hidden="true"></i>
              <span class="inline-block font-['Montserrat',sans-serif] text-[11px] leading-none font-normal uppercase tracking-[0.04em] text-gray-400 dark:text-gray-400" data-newsletter-header-label>Boletín</span>
            </a>

            <button
              type="button"
              class="js-menu-toggle relative inline-flex h-11 w-11 items-center justify-center rounded-full text-gray-700 dark:text-gray-300 transition-colors duration-200 hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white"
              aria-expanded="false"
              aria-controls="js-menu-panel"
              aria-label="Abrir menú de secciones"
            >
              <i class="fa-solid fa-bars text-lg" aria-hidden="true"></i>
              <span
                class="hidden absolute right-0.5 top-0.5 min-h-4 min-w-4 items-center justify-center rounded-full bg-[#E7D7B8] dark:bg-amber-900/80 px-1 text-[0.58rem] font-['Montserrat',sans-serif] font-semibold leading-none text-[#3F3424] dark:text-amber-200 ring-2 ring-white dark:ring-[#1a2529] sm:right-0 sm:top-0 sm:min-h-[1.15rem] sm:min-w-[1.15rem] sm:px-1.5 sm:text-[0.62rem]"
                data-reading-list-menu-dot
                aria-hidden="true"
              ></span>
              <span
                class="hidden absolute bottom-0.5 right-0.5 min-h-4 min-w-4 items-center justify-center rounded-full bg-[#DCE7E1] dark:bg-emerald-900/80 px-1 text-[0.58rem] font-['Montserrat',sans-serif] font-semibold leading-none text-[#31453D] dark:text-emerald-200 ring-2 ring-white dark:ring-[#1a2529] sm:bottom-0 sm:right-0 sm:min-h-[1.15rem] sm:min-w-[1.15rem] sm:px-1.5 sm:text-[0.62rem]"
                data-unread-menu-dot
                aria-hidden="true"
              ></span>
            </button>
          </div>

          {% set desktopThemes = articulos.tags | topThemes(6) if articulos and articulos.tags else [] %}

          {% if page.url == '/' and desktopThemes.length %}
          <nav class="absolute inset-y-0 left-1/2 hidden -translate-x-1/2 items-center gap-8 lg:flex">
            {% for tag in desktopThemes %}
            <a
              href="/tema/{{ tag.slug }}/"
              class="whitespace-nowrap text-sm font-semibold text-gray-700 dark:text-gray-300 transition-colors duration-200 hover:text-gray-900 dark:text-white"
            >
              {{ tag.name | themeName }}
            </a>
            {% endfor %}
            <a
              href="/temas/"
              class="whitespace-nowrap text-sm font-semibold text-gray-500 dark:text-gray-400 transition-colors duration-200 hover:text-gray-900 dark:text-white"
            >
              Más temas
            </a>
            <a
              href="/audios/"
              class="inline-flex h-11 w-11 items-center justify-center rounded-full text-gray-500 dark:text-gray-400 transition-colors duration-200 hover:bg-gray-100 dark:bg-gray-800 hover:text-gray-900 dark:text-white"
              aria-label="Ir a audios y podcast"
            >
              <i class="fa-solid fa-headphones-simple text-[0.95rem]" aria-hidden="true"></i>
            </a>
            <a
              href="/boletin/"
              class="inline-flex min-h-11 items-center gap-2 rounded-full border border-[#DDD] dark:border-gray-700 bg-[#F4F1E9] dark:bg-gray-800 px-4 py-2 text-sm font-semibold uppercase tracking-[0.08em] text-[#1F2937] dark:text-white transition-colors duration-200 hover:bg-[#ECE6DA] dark:bg-gray-700"
              data-newsletter-cta
            >
              <span>Boletín</span>
            </a>
          </nav>
          {% endif %}
        </div>

        {% if page.url != '/' and desktopThemes.length %}
        <div class="border-t border-gray-200 dark:border-gray-800">
          <div class="mx-auto hidden max-w-7xl items-center gap-8 overflow-x-auto px-6 py-4 lg:flex">
            {% for tag in desktopThemes %}
            <a
              href="/tema/{{ tag.slug }}/"
              class="whitespace-nowrap text-sm font-semibold text-gray-700 dark:text-gray-300 transition-colors duration-200 hover:text-gray-900 dark:text-white"
            >
              {{ tag.name | themeName }}
            </a>
            {% endfor %}
            <a
              href="/temas/"
              class="whitespace-nowrap text-sm font-semibold text-gray-500 dark:text-gray-400 transition-colors duration-200 hover:text-gray-900 dark:text-white"
            >
              Más temas
            </a>
            <a
              href="/audios/"
              class="inline-flex h-11 w-11 items-center justify-center rounded-full text-gray-500 dark:text-gray-400 transition-colors duration-200 hover:bg-gray-100 dark:bg-gray-800 hover:text-gray-900 dark:text-white"
              aria-label="Ir a audios y podcast"
            >
              <i class="fa-solid fa-headphones-simple text-[0.95rem]" aria-hidden="true"></i>
            </a>
            <a
              href="/boletin/"
              class="inline-flex min-h-11 items-center gap-2 rounded-full border border-[#DDD] dark:border-gray-700 bg-[#F4F1E9] dark:bg-gray-800 px-4 py-2 text-sm font-semibold uppercase tracking-[0.08em] text-[#1F2937] dark:text-white transition-colors duration-200 hover:bg-[#ECE6DA] dark:bg-gray-700"
              data-newsletter-cta
            >
              <span>Boletín</span>
            </a>
          </div>
        </div>
        {% endif %}

        <div
          id="js-menu-panel"
          class="js-menu-panel absolute inset-x-0 top-full hidden border-t border-gray-200 dark:border-gray-800 bg-white dark:bg-[#1a2529] shadow-md"
        >
          <div class="mx-auto max-w-7xl px-4 py-5 sm:px-6 lg:px-8">
            <div class="flex flex-col gap-5">
              <form action="/buscar/" method="get" class="border-b border-gray-200 dark:border-gray-800 pb-5">
                <div class="relative">
                  <label for="menu-search" class="sr-only">Buscar</label>
                  <input
                    id="menu-search"
                    name="q"
                    type="search"
                    inputmode="search"
                    autocomplete="off"
                    placeholder="Buscar"
                    class="block min-h-12 w-full min-w-0 rounded-full border border-gray-300 dark:border-gray-600 bg-white dark:bg-[#1a2529] px-4 py-3 pr-14 text-base text-gray-900 dark:text-white outline-none transition-colors duration-200 placeholder:text-gray-400 dark:text-gray-400 focus:border-gray-900"
                  >
                  <button
                    type="submit"
                    class="absolute right-1 top-1 inline-flex h-10 w-10 items-center justify-center rounded-full text-sm text-gray-500 dark:text-gray-400 transition-colors duration-200 hover:bg-gray-100 dark:hover:bg-[#202b31] hover:text-gray-900 dark:hover:text-white"
                    aria-label="Buscar"
                  >
                    <i class="fa-solid fa-arrow-right text-[0.95rem]" aria-hidden="true"></i>
                  </button>
                </div>
              </form>

              <div class="flex flex-col gap-4">
                <a href="/" class="text-sm font-semibold uppercase tracking-[0.08em] text-gray-900 dark:text-white">
                  Portada
                </a>
                <a
                  href="/temas/"
                  class="text-sm font-semibold uppercase tracking-[0.08em] {% if page.url == '/temas/' %}text-gray-900 dark:text-white{% else %}text-gray-700 dark:text-gray-300 transition-colors duration-200 hover:text-gray-900 dark:text-white{% endif %}"
                >
                  Temas
                </a>
                <a
                  href="/audios/"
                  class="text-sm font-semibold uppercase tracking-[0.08em] {% if page.url == '/audios/' or page.url == '/barra-audio/' %}text-gray-900 dark:text-white{% else %}text-gray-700 dark:text-gray-300 transition-colors duration-200 hover:text-gray-900 dark:text-white{% endif %}"
                >
                  Audios
                </a>
                <a
                  href="/lista-de-lectura/"
                  class="inline-flex items-center gap-3 text-sm font-semibold uppercase tracking-[0.08em] {% if page.url == '/lista-de-lectura/' %}text-gray-900 dark:text-white{% else %}text-gray-700 dark:text-gray-300 transition-colors duration-200 hover:text-gray-900 dark:text-white{% endif %}"
                >
                  <span>Lista de lectura</span>
                  <span
                    class="hidden rounded-full border border-[#DDD4C5] dark:border-amber-900/40 bg-[#F8F5EE] dark:bg-amber-900/40 px-2.5 py-1 font-['Montserrat',sans-serif] text-[0.68rem] font-semibold uppercase tracking-[0.12em] text-[#6B6253] dark:text-amber-200"
                    data-reading-list-count-badge
                  ></span>
                </a>
                <a
                  href="/nuevo/"
                  class="inline-flex items-center gap-3 text-sm font-semibold uppercase tracking-[0.08em] {% if page.url == '/nuevo/' %}text-gray-900 dark:text-white{% else %}text-gray-700 dark:text-gray-300 transition-colors duration-200 hover:text-gray-900 dark:text-white{% endif %}"
                >
                  <span>Nuevo para ti</span>
                  <span
                    class="hidden rounded-full bg-[#DCE7E1] dark:bg-emerald-900/40 px-2.5 py-1 font-['Montserrat',sans-serif] text-[0.68rem] font-semibold uppercase tracking-[0.12em] text-[#31453D] dark:text-emerald-200"
                    data-unread-count-badge
                  ></span>
                </a>
                <a
                  href="/populares/"
                  class="text-sm font-semibold uppercase tracking-[0.08em] {% if page.url == '/populares/' %}text-gray-900 dark:text-white{% else %}text-gray-700 dark:text-gray-300 transition-colors duration-200 hover:text-gray-900 dark:text-white{% endif %}"
                >
                  Populares
                </a>
              </div>

              <div class="border-t border-gray-200 dark:border-gray-800 pt-5">
                <div class="flex flex-col gap-4">
                  <a
                    href="/quienes-somos/"
                    class="text-sm font-semibold uppercase tracking-[0.08em] {% if page.url == '/quienes-somos/' %}text-gray-900 dark:text-white{% else %}text-gray-700 dark:text-gray-300 transition-colors duration-200 hover:text-gray-900 dark:hover:text-white{% endif %}"
                  >
                    Quiénes somos
                  </a>
                  <a
                    href="https://foro.aldeapucela.org/t/acerca-de-la-otra-pucela/966"
                    class="text-sm font-semibold uppercase tracking-[0.08em] text-gray-700 dark:text-gray-300 transition-colors duration-200 hover:text-gray-900 dark:hover:text-white"
                  >
                    Colaborar
                  </a>
                  <a
                    href="/contacto/"
                    class="text-sm font-semibold uppercase tracking-[0.08em] {% if page.url == '/contacto/' %}text-gray-900 dark:text-white{% else %}text-gray-700 dark:text-gray-300 transition-colors duration-200 hover:text-gray-900 dark:hover:text-white{% endif %}"
                  >
                    Contacto
                  </a>
                  <div class="border-t border-gray-100 dark:border-gray-800/50 pt-4">
                    <div class="flex items-center gap-3">
                      <span class="text-[0.7rem] font-semibold uppercase tracking-[0.15em] text-gray-400 dark:text-gray-500">Redes</span>
                      <div class="flex items-center gap-1.5">
                        <a
                          href="https://bsky.app/profile/otrapucela.org"
                          class="inline-flex h-10 w-10 items-center justify-center rounded-full text-gray-400 dark:text-gray-500 transition-colors duration-200 hover:text-gray-700 dark:hover:text-gray-300"
                          aria-label="Bluesky de La Otra Pucela"
                          target="_blank"
                          rel="noreferrer"
                        >
                          <i class="fa-brands fa-bluesky text-[0.95rem]" aria-hidden="true"></i>
                        </a>
                        <a
                          href="https://www.instagram.com/otrapucela"
                          class="inline-flex h-10 w-10 items-center justify-center rounded-full text-gray-400 dark:text-gray-500 transition-colors duration-200 hover:text-gray-700 dark:hover:text-gray-300"
                          aria-label="Instagram de La Otra Pucela"
                          target="_blank"
                          rel="noreferrer"
                        >
                          <i class="fa-brands fa-instagram text-[0.95rem]" aria-hidden="true"></i>
                        </a>
                      </div>
                    </div>
                  </div>
                  <div class="flex items-center justify-between border-t border-gray-100 dark:border-gray-800/50 pt-5">
                    <span class="text-[0.7rem] font-semibold uppercase tracking-[0.15em] text-gray-400 dark:text-gray-500">Apariencia</span>
                    <button
                      type="button"
                      class="js-theme-toggle inline-flex h-9 w-9 items-center justify-center rounded-full border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-500 dark:text-gray-400 transition-all duration-200 hover:border-gray-300 dark:hover:border-gray-600 hover:text-gray-900 dark:hover:text-white"
                      title="Cambiar tema"
                      aria-label="Cambiar tema"
                    >
                      <i class="js-theme-toggle-icon fa-solid fa-moon text-sm" aria-hidden="true"></i>
                    </button>
                  </div>
                </div>
              </div>

              <a
                href="/boletin/"
                class="inline-flex min-h-12 items-center justify-center gap-2 rounded-full border border-[#DDD] dark:border-gray-700 bg-[#F4F1E9] dark:bg-gray-800 px-4 py-3 text-sm font-semibold uppercase tracking-[0.08em] text-[#1F2937] dark:text-white transition-colors duration-200 hover:bg-[#ECE6DA] dark:bg-gray-700"
                data-newsletter-cta
              >
                <i class="fa-regular fa-envelope text-[0.95rem]" aria-hidden="true"></i>
                <span>Recibir por correo</span>
              </a>

              <button
                type="button"
                class="js-install-app-trigger hidden min-h-12 w-full items-center justify-between gap-4 rounded-2xl border border-[#DDD7CC] dark:border-gray-700 bg-[#FFFDF8] dark:bg-gray-900 px-4 py-3 text-left text-sm text-gray-800 dark:text-gray-200 shadow-sm transition-colors duration-200 hover:bg-[#F8F4EC] dark:bg-gray-800"
                aria-haspopup="dialog"
              >
                <span class="flex items-center gap-3">
                  <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-[#F5F1E7] dark:bg-gray-800 text-[#2F3E46] dark:text-gray-200">
                    <i class="fa-solid fa-mobile-screen-button text-base" aria-hidden="true"></i>
                  </span>
                  <span class="min-w-0">
                    <span class="block font-semibold uppercase tracking-[0.08em] text-gray-900 dark:text-white">Añadir a pantalla de inicio</span>
                    <span class="mt-1 block text-sm leading-[1.55] text-gray-500 dark:text-gray-400 js-install-app-description">Ten La Otra Pucela más a mano en tu móvil.</span>
                  </span>
                </span>
                <i class="fa-solid fa-chevron-right text-sm text-gray-400 dark:text-gray-400" aria-hidden="true"></i>
              </button>

              {% if articulos and articulos.tags and articulos.tags.length %}
              <div class="border-t border-gray-200 dark:border-gray-800 pt-5 lg:hidden">
                <p class="text-sm font-semibold uppercase tracking-[0.08em] text-gray-500 dark:text-gray-400">Temas</p>
                <div class="mt-4 flex flex-wrap gap-3">
                  {% for tag in articulos.tags %}
                  <a
                    href="/tema/{{ tag.slug }}/"
                    class="inline-flex min-h-11 items-center rounded-full border border-gray-200 dark:border-gray-800 bg-white dark:bg-[#1a2529] px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 transition-colors duration-200 hover:bg-gray-100 dark:bg-gray-800 hover:text-gray-900 dark:text-white"
                  >
                    {{ tag.name | themeName }}
                  </a>
                  {% endfor %}
                </div>
              </div>
              {% endif %}

              <div class="border-t border-gray-200 dark:border-gray-800 pt-5">
                <button
                  type="button"
                  class="js-share-btn inline-flex min-h-12 w-full items-center justify-center gap-2 rounded-full bg-[#2F3E46] px-4 py-3 text-sm font-semibold text-white transition-colors duration-200 hover:bg-[#253138]"
                  data-share-source="menu-drawer"
                  data-share-content-type="homepage"
                  data-share-content-id="homepage"
                  data-url="/"
                  data-title="La Otra Pucela - Informacion vecinal, util e independiente sobre Valladolid"
                  aria-label="Compartir portada"
                >
                  <i class="fa-solid fa-share-nodes js-share-btn-icon text-base" aria-hidden="true"></i>
                  <span class="js-share-btn-label">Compartir</span>
                </button>
              </div>
            </div>
          </div>
        </div>
      </header>

      {% if page.url == '/' %}
      <section
        class="border-y border-[#DDD7CC] dark:border-gray-700 bg-[#F6F1E7] dark:bg-gray-800 px-4 py-4 sm:px-6 sm:py-[18px] lg:hidden"
        aria-label="Identidad editorial"
      >
        <div class="mx-auto flex max-w-7xl flex-col items-start text-left">
          <p class="font-['Montserrat',sans-serif] text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-[#5F5645] dark:text-gray-400 dark:text-gray-500 sm:text-[0.78rem] sm:tracking-[0.28em]">
            Información vecinal, útil e independiente sobre Valladolid
          </p>
        </div>
      </section>
      {% endif %}

      <main class="{% if page.url == '/' %}mt-0{% else %}mt-2 md:mt-4{% endif %}">
        {{ content | safe }}
      </main>

      <footer class="border-t border-gray-200 dark:border-gray-800 bg-white dark:bg-[#1a2529]">
        <div class="mx-auto flex max-w-7xl flex-col gap-5 px-4 py-8 text-sm text-gray-600 dark:text-gray-400 {% if ogType == 'article' %}pb-28 md:pb-8{% endif %} sm:px-6 lg:px-8">
          {% if page.url != '/boletin/' %}
          {% set subscriptionVariant = 'inline' %}
          {% set subscriptionTitle = 'Valladolid en tu email' %}
          {% set subscriptionDescription = '' %}
          {% set subscriptionButton = 'Apuntarme' %}
          {% set subscriptionSource = 'footer' %}
          {% include "partials/subscription-module.njk" %}
          {% endif %}

          <img
            src="/assets/logo-wordmark.png"
            alt="La Otra Pucela"
            class="h-auto w-[100%] md:w-[50%] lg:w-[30%] self-start dark:hidden"
            loading="lazy"
            decoding="async"
          >
          <img
            src="/assets/logo-wordmark.dark.png"
            alt="La Otra Pucela"
            class="hidden h-auto w-[100%] md:w-[50%] lg:w-[30%] self-start dark:block"
            loading="lazy"
            decoding="async"
          >
          <p>Proyecto comunitario e independiente sobre Valladolid</p>
          <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center sm:gap-4">
            {% set absoluteFeedUrl = site.siteUrl + site.feedPath %}
            {% set absolutePodcastUrl = site.podcastFeedUrl %}
            <a
              href="/audios/"
              class="inline-flex min-h-11 items-center gap-2 font-medium text-gray-800 dark:text-gray-200 transition-colors duration-200 hover:text-gray-950"
            >
              <i class="fa-solid fa-headphones-simple text-[0.95rem] text-[#2F3E46] dark:text-gray-200" aria-hidden="true"></i>
              <span>Audios y podcast</span>
            </a>
            <a
              href="{{ site.feedPath }}"
              class="inline-flex min-h-11 items-center gap-2 self-start py-2 font-medium text-gray-700 dark:text-gray-300 transition-colors duration-200 hover:text-gray-950"
              data-rss-trigger
              data-feed-url="{{ absoluteFeedUrl }}"
              data-podcast-url="{{ absolutePodcastUrl }}"
              data-default-feed="rss"
              aria-haspopup="dialog"
            >
              <i class="fa-solid fa-rss text-[0.95rem] text-[#8A5A2B] dark:text-yellow-500" aria-hidden="true"></i>
              <span>RSS</span>
            </a>
            <a
              href="https://creativecommons.org/licenses/by-sa/4.0/deed.es"
              class="inline-flex min-h-11 items-center font-medium text-gray-800 dark:text-gray-200 transition-colors duration-200 hover:text-gray-950"
              target="_blank"
              rel="noreferrer"
            >
              Licencia CC BY-SA 4.0
            </a>
          </div>
        </div>
      </footer>

      {% include "partials/article-lightbox.njk" %}

      <dialog
        class="w-[min(92vw,42rem)] rounded-[2rem] border border-[#DDD7CC] dark:border-gray-700 bg-[#FFFDF8] dark:bg-gray-900 p-0 text-gray-900 dark:text-white shadow-2xl backdrop:bg-[#2F3E46]/55"
        data-rss-dialog
        aria-labelledby="rss-dialog-title"
      >
        <div class="relative overflow-hidden rounded-[2rem]">
          <button
            type="button"
            class="absolute right-4 top-4 inline-flex h-11 w-11 items-center justify-center rounded-full text-gray-400 dark:text-gray-400 transition-colors duration-200 hover:bg-[#F3EEE3] dark:bg-gray-700 hover:text-gray-700 dark:text-gray-300 focus:outline-none focus:ring-2 focus:ring-[#8A5A2B]/30"
            data-rss-close
            aria-label="Cerrar"
          >
            <i class="fa-solid fa-xmark text-xl" aria-hidden="true"></i>
          </button>

          <div class="px-5 pb-6 pt-8 sm:px-8 sm:pb-8">
            <div class="mx-auto flex h-24 w-24 items-center justify-center rounded-full bg-[#2F3E46] text-white shadow-sm">
              <i class="fa-solid fa-rss text-[2rem]" aria-hidden="true"></i>
            </div>

            <div class="mt-6 text-center">
              <h2 id="rss-dialog-title" class="font-serif text-[2rem] font-semibold leading-tight tracking-tight text-[#2F3E46] dark:text-gray-200 sm:text-[2.4rem]">
                Suscríbete al RSS
              </h2>
              <p class="mt-4 text-base leading-[1.6] text-gray-600 dark:text-gray-400 sm:text-[1.15rem]">
                Recibe las nuevas publicaciones en tu lector favorito. Puedes copiar la URL del feed o abrirla directamente en algunas apps populares.
              </p>
            </div>

            <section class="mt-8 border-t border-[#E7E0D3] dark:border-gray-700 pt-8">
              <h3 class="flex items-center gap-3 text-[1.55rem] font-semibold tracking-tight text-[#2F3E46] dark:text-gray-200">
                <i class="fa-regular fa-copy text-[1.2rem]" aria-hidden="true"></i>
                <span>Feeds disponibles</span>
              </h3>
              <div class="mt-5 space-y-4">
                <div class="rounded-[1.5rem] border border-[#DDD7CC] dark:border-gray-700 bg-white dark:bg-[#1a2529] p-4 sm:p-5">
                  <div class="flex items-center gap-3">
                    <i class="fa-solid fa-newspaper text-[1.35rem] text-[#8A5A2B] dark:text-yellow-500" aria-hidden="true"></i>
                    <div>
                      <p class="text-base font-semibold leading-tight text-[#2F3E46] dark:text-gray-200">RSS general</p>
                      <p class="mt-1 text-sm leading-[1.6] text-gray-500 dark:text-gray-400 sm:text-base">
                        Todas las publicaciones para lectores RSS como Feedly o Inoreader.
                      </p>
                    </div>
                  </div>
                  <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-stretch">
                    <input
                      type="text"
                      readonly
                      class="min-h-12 flex-1 rounded-2xl border border-[#DDD7CC] dark:border-gray-700 bg-white dark:bg-[#1a2529] px-4 py-3 text-sm leading-[1.5] text-gray-800 dark:text-gray-200 outline-none ring-0 sm:text-base"
                      data-rss-feed-input="rss"
                    >
                    <button
                      type="button"
                      class="inline-flex min-h-12 items-center justify-center gap-2 rounded-2xl bg-[#2F3E46] px-5 py-3 text-base font-semibold text-white transition-colors duration-200 hover:bg-[#253138] focus:outline-none focus:ring-2 focus:ring-[#2F3E46]/30"
                      data-rss-copy="rss"
                    >
                      <i class="fa-regular fa-copy text-base" aria-hidden="true"></i>
                      <span data-rss-copy-label="rss">Copiar</span>
                    </button>
                  </div>
                </div>

                <div class="rounded-[1.5rem] border border-[#DDD7CC] dark:border-gray-700 bg-white dark:bg-[#1a2529] p-4 sm:p-5">
                  <div class="flex items-center gap-3">
                    <i class="fa-solid fa-podcast text-[1.35rem] text-[#2F3E46] dark:text-gray-200" aria-hidden="true"></i>
                    <div>
                      <p class="text-base font-semibold leading-tight text-[#2F3E46] dark:text-gray-200">Feed de podcast</p>
                      <p class="mt-1 text-sm leading-[1.6] text-gray-500 dark:text-gray-400 sm:text-base">
                        Solo los artículos con audio, preparado para apps de podcast.
                      </p>
                    </div>
                  </div>
                  <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-stretch">
                    <input
                      type="text"
                      readonly
                      class="min-h-12 flex-1 rounded-2xl border border-[#DDD7CC] dark:border-gray-700 bg-white dark:bg-[#1a2529] px-4 py-3 text-sm leading-[1.5] text-gray-800 dark:text-gray-200 outline-none ring-0 sm:text-base"
                      data-rss-feed-input="podcast"
                    >
                    <button
                      type="button"
                      class="inline-flex min-h-12 items-center justify-center gap-2 rounded-2xl bg-[#8A5A2B] px-5 py-3 text-base font-semibold text-white transition-colors duration-200 hover:bg-[#74491F] focus:outline-none focus:ring-2 focus:ring-[#8A5A2B]/30"
                      data-rss-copy="podcast"
                    >
                      <i class="fa-regular fa-copy text-base" aria-hidden="true"></i>
                      <span data-rss-copy-label="podcast">Copiar</span>
                    </button>
                  </div>
                  <div class="mt-5 rounded-[1.25rem] border border-[#E7E0D3] dark:border-gray-700 bg-[#FCFAF5] dark:bg-gray-900 p-4">
                    <p class="text-sm font-semibold tracking-tight text-[#2F3E46] dark:text-gray-200 sm:text-base">
                      Abrir en apps compatibles
                    </p>
                    <div class="mt-3 grid gap-3 sm:grid-cols-2">
                      {% if site.podcast.platforms.spotify.enabled %}
                      <a
                        class="inline-flex min-h-12 items-center justify-center gap-2 rounded-2xl border border-[#DDD7CC] dark:border-gray-700 bg-white dark:bg-[#1a2529] px-4 py-3 text-sm font-medium text-gray-800 dark:text-gray-200 transition-colors duration-200 hover:border-[#BFD3D8] dark:border-gray-600 hover:bg-[#F6FAFB] sm:text-base"
                        data-podcast-service="spotify"
                        href="{{ site.podcast.platforms.spotify.url }}"
                        target="_blank"
                        rel="noreferrer"
                      >
                        <i class="fa-brands fa-spotify text-[0.95rem] text-[#2F3E46] dark:text-gray-200" aria-hidden="true"></i>
                        <span>Spotify</span>
                      </a>
                      {% endif %}
                      {% if site.podcast.platforms.apple.enabled %}
                      <a
                        class="inline-flex min-h-12 items-center justify-center gap-2 rounded-2xl border border-[#DDD7CC] dark:border-gray-700 bg-white dark:bg-[#1a2529] px-4 py-3 text-sm font-medium text-gray-800 dark:text-gray-200 transition-colors duration-200 hover:border-[#BFD3D8] dark:border-gray-600 hover:bg-[#F6FAFB] sm:text-base"
                        data-podcast-service="apple"
                        href="{{ site.podcast.platforms.apple.url }}"
                        target="_blank"
                        rel="noreferrer"
                      >
                        <i class="fa-brands fa-apple text-[0.95rem] text-[#2F3E46] dark:text-gray-200" aria-hidden="true"></i>
                        <span>Apple Podcast</span>
                      </a>
                      {% endif %}
                      <a
                        class="inline-flex min-h-12 items-center justify-center gap-2 rounded-2xl border border-[#DDD7CC] dark:border-gray-700 bg-white dark:bg-[#1a2529] px-4 py-3 text-sm font-medium text-gray-800 dark:text-gray-200 transition-colors duration-200 hover:border-[#BFD3D8] dark:border-gray-600 hover:bg-[#F6FAFB] sm:text-base"
                        data-podcast-service="antennapod"
                        target="_blank"
                        rel="noreferrer"
                      >
                        <i class="fa-solid fa-mobile-screen-button text-[0.95rem] text-[#2F3E46] dark:text-gray-200" aria-hidden="true"></i>
                        <span>AntennaPod</span>
                      </a>
                      <a
                        class="inline-flex min-h-12 items-center justify-center gap-2 rounded-2xl border border-[#DDD7CC] dark:border-gray-700 bg-white dark:bg-[#1a2529] px-4 py-3 text-sm font-medium text-gray-800 dark:text-gray-200 transition-colors duration-200 hover:border-[#BFD3D8] dark:border-gray-600 hover:bg-[#F6FAFB] sm:text-base"
                        data-podcast-service="overcast"
                        rel="noreferrer"
                      >
                        <i class="fa-solid fa-headphones-simple text-[0.95rem] text-[#2F3E46] dark:text-gray-200" aria-hidden="true"></i>
                        <span>Overcast</span>
                      </a>
                    </div>
                    <div class="mt-4 space-y-2 text-sm leading-[1.6] text-gray-600 dark:text-gray-400 sm:text-[0.95rem]">
                      <p>
                        <strong class="font-semibold text-[#2F3E46] dark:text-gray-200">Apple Podcasts:</strong>
                        abre Biblioteca, toca <strong class="font-semibold">...</strong> y elige <strong class="font-semibold">Añadir un programa por URL</strong>.
                      </p>
                      <p>
                        <strong class="font-semibold text-[#2F3E46] dark:text-gray-200">Pocket Casts:</strong>
                        pega la URL del feed en la búsqueda de <strong class="font-semibold">Discover</strong> para seguirlo.
                      </p>
                    </div>
                  </div>
                </div>
              </div>
              <p class="mt-4 text-sm leading-[1.6] text-gray-500 dark:text-gray-400 sm:text-base">
                Usa el RSS general para lectura y el feed de podcast si quieres escuchar los artículos en una app de podcasts.
              </p>
            </section>

            <section class="mt-8 border-t border-[#E7E0D3] dark:border-gray-700 pt-8">
              <h3 class="flex items-center gap-3 text-[1.55rem] font-semibold tracking-tight text-[#2F3E46] dark:text-gray-200">
                <i class="fa-solid fa-arrow-up-right-from-square text-[1.05rem]" aria-hidden="true"></i>
                <span>Suscripción rápida</span>
              </h3>
              <p class="mt-4 text-sm leading-[1.6] text-gray-500 dark:text-gray-400 sm:text-base">
                Abre el feed directamente en uno de estos lectores:
              </p>
              <div class="mt-5 grid gap-3 sm:grid-cols-2">
                <a class="flex min-h-12 items-center gap-3 rounded-2xl border border-[#DDD7CC] dark:border-gray-700 bg-white dark:bg-[#1a2529] px-4 py-4 text-base font-medium text-gray-800 dark:text-gray-200 transition-colors duration-200 hover:border-[#C8BCA5] dark:border-gray-600 hover:bg-[#F8F4EC] dark:bg-gray-800" data-rss-reader="feedly" target="_blank" rel="noreferrer">
                  <i class="fa-solid fa-rss text-[#8A5A2B] dark:text-yellow-500" aria-hidden="true"></i>
                  <span>Feedly</span>
                </a>
                <a class="flex min-h-12 items-center gap-3 rounded-2xl border border-[#DDD7CC] dark:border-gray-700 bg-white dark:bg-[#1a2529] px-4 py-4 text-base font-medium text-gray-800 dark:text-gray-200 transition-colors duration-200 hover:border-[#C8BCA5] dark:border-gray-600 hover:bg-[#F8F4EC] dark:bg-gray-800" data-rss-reader="inoreader" target="_blank" rel="noreferrer">
                  <i class="fa-solid fa-rss text-[#8A5A2B] dark:text-yellow-500" aria-hidden="true"></i>
                  <span>Inoreader</span>
                </a>
                <a class="flex min-h-12 items-center gap-3 rounded-2xl border border-[#DDD7CC] dark:border-gray-700 bg-white dark:bg-[#1a2529] px-4 py-4 text-base font-medium text-gray-800 dark:text-gray-200 transition-colors duration-200 hover:border-[#C8BCA5] dark:border-gray-600 hover:bg-[#F8F4EC] dark:bg-gray-800" data-rss-reader="newsblur" target="_blank" rel="noreferrer">
                  <i class="fa-solid fa-rss text-[#8A5A2B] dark:text-yellow-500" aria-hidden="true"></i>
                  <span>NewsBlur</span>
                </a>
                <a class="flex min-h-12 items-center gap-3 rounded-2xl border border-[#DDD7CC] dark:border-gray-700 bg-white dark:bg-[#1a2529] px-4 py-4 text-base font-medium text-gray-800 dark:text-gray-200 transition-colors duration-200 hover:border-[#C8BCA5] dark:border-gray-600 hover:bg-[#F8F4EC] dark:bg-gray-800" data-rss-reader="theoldreader" target="_blank" rel="noreferrer">
                  <i class="fa-solid fa-rss text-[#8A5A2B] dark:text-yellow-500" aria-hidden="true"></i>
                  <span>The Old Reader</span>
                </a>
              </div>
            </section>

            <section class="mt-8 rounded-[1.75rem] bg-[#F5F1E7] dark:bg-gray-800 px-5 py-6 sm:px-6">
              <h3 class="flex items-center gap-3 text-[1.4rem] font-semibold tracking-tight text-[#2F3E46] dark:text-gray-200">
                <i class="fa-solid fa-circle-info text-[1.1rem]" aria-hidden="true"></i>
                <span>Cómo añadirlo manualmente</span>
              </h3>
              <ol class="mt-5 space-y-3 text-sm leading-[1.6] text-gray-700 dark:text-gray-300 sm:text-base">
                <li>1. Abre tu aplicación o servicio de lectura RSS.</li>
                <li>2. Busca una opción como “Añadir feed”, “Suscribirse” o el icono +.</li>
                <li>3. Si es una app de podcast, usa el feed de podcast; si es un lector RSS, usa el general.</li>
                <li>4. Confirma la suscripción y listo.</li>
              </ol>
            </section>
          </div>
        </div>
      </dialog>

      <dialog
        class="w-[min(92vw,32rem)] rounded-[2rem] border border-[#DDD7CC] dark:border-gray-700 bg-[#FFFDF8] dark:bg-gray-900 p-0 text-gray-900 dark:text-white shadow-2xl backdrop:bg-[#2F3E46]/55"
        data-install-dialog
        aria-labelledby="install-dialog-title"
      >
        <div class="relative overflow-hidden rounded-[2rem]">
          <button
            type="button"
            class="absolute right-4 top-4 inline-flex h-11 w-11 items-center justify-center rounded-full text-gray-400 dark:text-gray-400 transition-colors duration-200 hover:bg-[#F3EEE3] dark:bg-gray-700 hover:text-gray-700 dark:text-gray-300 focus:outline-none focus:ring-2 focus:ring-[#8A5A2B]/30"
            data-install-close
            aria-label="Cerrar"
          >
            <i class="fa-solid fa-xmark text-xl" aria-hidden="true"></i>
          </button>

          <div class="px-5 pb-6 pt-8 sm:px-8 sm:pb-8">
            <div class="mx-auto flex h-24 w-24 items-center justify-center rounded-full bg-[#2F3E46] text-white shadow-sm">
              <i class="fa-solid fa-mobile-screen-button text-[2rem]" aria-hidden="true"></i>
            </div>

            <div class="mt-6 text-center">
              <h2 id="install-dialog-title" class="font-serif text-[1.9rem] font-semibold leading-tight tracking-tight text-[#2F3E46] dark:text-gray-200 sm:text-[2.2rem]">
                Añádelo a tu pantalla de inicio
              </h2>
              <p class="mt-4 text-base leading-[1.6] text-gray-600 dark:text-gray-400 sm:text-[1.08rem] js-install-dialog-copy">
                Sigue estos pasos para tener La Otra Pucela más a mano en tu móvil o tablet.
              </p>
            </div>

            <section class="mt-8 rounded-[1.75rem] bg-[#F5F1E7] dark:bg-gray-800 px-5 py-6 sm:px-6">
              <h3 class="flex items-center gap-3 text-[1.35rem] font-semibold tracking-tight text-[#2F3E46] dark:text-gray-200">
                <i class="fa-solid fa-circle-info text-[1.1rem]" aria-hidden="true"></i>
                <span>Pasos</span>
              </h3>
              <ol class="mt-5 space-y-3 text-sm leading-[1.6] text-gray-700 dark:text-gray-300 sm:text-base js-install-steps">
                <li>1. Abre el menú de compartir de tu navegador.</li>
                <li>2. Busca la opción “Añadir a pantalla de inicio”.</li>
                <li>3. Confirma el nombre y pulsa “Añadir”.</li>
              </ol>
            </section>

            <div class="mt-6 flex flex-col gap-3 sm:flex-row">
              <button
                type="button"
                class="js-install-app-confirm inline-flex min-h-12 flex-1 items-center justify-center gap-2 rounded-2xl bg-[#2F3E46] px-5 py-3 text-base font-semibold text-white transition-colors duration-200 hover:bg-[#253138] focus:outline-none focus:ring-2 focus:ring-[#2F3E46]/30"
              >
                <i class="fa-solid fa-download text-base" aria-hidden="true"></i>
                <span class="js-install-app-confirm-label">Continuar</span>
              </button>
              <button
                type="button"
                class="inline-flex min-h-12 items-center justify-center rounded-2xl border border-[#DDD7CC] dark:border-gray-700 bg-white dark:bg-[#1a2529] px-5 py-3 text-base font-semibold text-gray-700 dark:text-gray-300 transition-colors duration-200 hover:bg-[#F8F4EC] dark:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-[#2F3E46]/15"
                data-install-close
              >
                Cerrar
              </button>
            </div>
          </div>
        </div>
      </dialog>

      <dialog
        class="featured-photo-dialog"
        data-featured-photo-dialog
        aria-labelledby="featured-photo-dialog-title"
      >
        <div class="featured-photo-dialog__surface">
          <button
            type="button"
            class="featured-photo-dialog__close"
            data-featured-photo-close
            aria-label="Cerrar foto"
          >
            <i class="fa-solid fa-xmark text-xl" aria-hidden="true"></i>
          </button>

          <div class="featured-photo-dialog__layout">
            <img
              class="featured-photo-dialog__image"
              data-featured-photo-dialog-image
              alt=""
              loading="eager"
            >

            <div class="featured-photo-dialog__content">
              <p class="featured-photo-dialog__description" id="featured-photo-dialog-title" data-featured-photo-dialog-description></p>

              <div class="featured-photo-dialog__meta">
                <div class="featured-photo-dialog__meta-copy">
                  <a
                    class="featured-photo-dialog__meta-link"
                    data-featured-photo-dialog-author-link
                    target="_blank"
                    rel="noreferrer"
                  >
                    <span data-featured-photo-dialog-author></span>
                  </a>
                  <span class="featured-photo-dialog__meta-separator" aria-hidden="true">-</span>
                  <a
                    class="featured-photo-dialog__meta-link"
                    data-featured-photo-dialog-license-link
                    target="_blank"
                    rel="noreferrer"
                  >
                    <span data-featured-photo-dialog-license></span>
                  </a>
                </div>
                <div class="featured-photo-dialog__actions">
                  <a
                    class="featured-photo-dialog__source"
                    data-featured-photo-dialog-source
                    target="_blank"
                    rel="noreferrer"
                  >
                    <i class="fa-solid fa-arrow-up-right-from-square text-[0.9rem]" aria-hidden="true"></i>
                  </a>
                  <button
                    type="button"
                    class="featured-photo-dialog__source"
                    data-featured-photo-dialog-random
                    aria-label="Mostrar otra foto"
                    title="Mostrar otra foto"
                  >
                    <i class="fa-solid fa-shuffle text-[0.82rem]" aria-hidden="true"></i>
                  </button>
                  <button
                    type="button"
                    class="featured-photo-dialog__source js-share-btn"
                    data-featured-photo-dialog-share
                    data-share-source="featured-photo-dialog"
                    data-share-content-type="photo"
                  >
                    <i class="fa-solid fa-share-nodes js-share-btn-icon text-[0.82rem]" aria-hidden="true"></i>
                    <span class="sr-only js-share-btn-label">Compartir foto</span>
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </dialog>
    </div>

    <script src="/assets/js/main.js" type="module"></script>
  </body>
</html>
