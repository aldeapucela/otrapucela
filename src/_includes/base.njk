<!doctype html>
<html lang="es">
  <head>
    {% set resolvedCanonicalUrl = (canonicalUrl or page.url) | absoluteUrl(site.siteUrl) %}
    {% set resolvedOgImage = (ogImage or site.defaultSocialImage) | absoluteUrl(site.siteUrl) %}
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title or "La Otra Pucela" }}</title>
    <meta name="description" content="{{ description or 'Medio digital estático con artículos publicados desde Discourse.' }}">
    <meta name="theme-color" content="#5e2a70">
    <link rel="canonical" href="{{ resolvedCanonicalUrl }}">
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="shortcut icon" href="/favicon.ico">

    <meta property="og:type" content="{{ ogType or 'website' }}">
    <meta property="og:site_name" content="La Otra Pucela">
    <meta property="og:title" content="{{ ogTitle or title or 'La Otra Pucela' }}">
    <meta property="og:description" content="{{ ogDescription or description or 'Medio digital estático con artículos publicados desde Discourse.' }}">
    <meta property="og:url" content="{{ resolvedCanonicalUrl }}">
    <meta property="og:image" content="{{ resolvedOgImage }}">

    <meta name="twitter:card" content="{{ twitterCard or 'summary_large_image' }}">
    <meta name="twitter:title" content="{{ twitterTitle or ogTitle or title or 'La Otra Pucela' }}">
    <meta name="twitter:description" content="{{ twitterDescription or ogDescription or description or 'Medio digital estático con artículos publicados desde Discourse.' }}">
    <meta name="twitter:image" content="{{ resolvedOgImage }}">

    <link rel="alternate" type="application/rss+xml" title="{{ site.name }} RSS" href="{{ site.feedPath }}">
    <link rel="stylesheet" href="{{ assetManifest['assets/styles/main.css'] or '/assets/styles/main.css' }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600&display=swap"
    >
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    >
    <script src="{{ assetManifest['assets/js/matomo.js'] or '/assets/js/matomo.js' }}" defer></script>
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-800 antialiased">
    <div class="relative min-h-screen">
      <header
        id="js-header"
        class="relative sticky top-0 z-50 border-b border-gray-200 bg-white transition-transform duration-300 shadow-sm"
      >
        <div class="mx-auto flex min-h-16 max-w-7xl items-center justify-center px-4 py-4 sm:px-6 lg:px-8">
          <button
            type="button"
            class="js-menu-toggle absolute left-2 inline-flex h-11 w-11 items-center justify-center rounded-full text-gray-700 transition-colors duration-200 hover:bg-gray-100 hover:text-gray-900 sm:left-4 lg:left-6"
            aria-expanded="false"
            aria-controls="js-menu-panel"
            aria-label="Abrir menú de secciones"
          >
            <i class="fa-solid fa-bars text-lg" aria-hidden="true"></i>
          </button>

          <a href="/" class="text-center text-gray-900 {% if page.url == '/' %}lg:hidden{% endif %}">
            <span class="block font-serif text-[1.75rem] font-extrabold uppercase tracking-[0.04em] sm:text-[2rem]">La Otra Pucela</span>
          </a>

          {% if page.url == '/' and articulos and articulos.tags and articulos.tags.length %}
          <nav class="absolute inset-y-0 left-1/2 hidden -translate-x-1/2 items-center gap-8 lg:flex">
            {% for tag in articulos.tags %}
            <a
              href="/tema/{{ tag.slug }}/"
              class="whitespace-nowrap text-sm font-semibold text-gray-700 transition-colors duration-200 hover:text-gray-900"
            >
              {{ tag.name | themeName }}
            </a>
            {% endfor %}
          </nav>
          {% endif %}
        </div>

        {% if page.url != '/' and articulos and articulos.tags and articulos.tags.length %}
        <div class="border-t border-gray-200">
          <div class="mx-auto hidden max-w-7xl items-center gap-8 overflow-x-auto px-6 py-4 lg:flex">
            {% for tag in articulos.tags %}
            <a
              href="/tema/{{ tag.slug }}/"
              class="whitespace-nowrap text-sm font-semibold text-gray-700 transition-colors duration-200 hover:text-gray-900"
            >
              {{ tag.name | themeName }}
            </a>
            {% endfor %}
          </div>
        </div>
        {% endif %}

        <div
          id="js-menu-panel"
          class="js-menu-panel absolute inset-x-0 top-full hidden border-t border-gray-200 bg-white shadow-md"
        >
          <div class="mx-auto max-w-7xl px-4 py-5 sm:px-6 lg:px-8">
            <div class="flex flex-col gap-5">
              <form action="/buscar/" method="get" class="border-b border-gray-200 pb-5">
                <div class="flex items-center gap-3">
                  <label for="menu-search" class="sr-only">Buscar</label>
                  <input
                    id="menu-search"
                    name="q"
                    type="search"
                    inputmode="search"
                    autocomplete="off"
                    placeholder="Buscar"
                    class="block min-h-12 w-full min-w-0 flex-1 rounded-full border border-gray-300 bg-white px-4 py-3 text-base text-gray-900 outline-none transition-colors duration-200 placeholder:text-gray-400 focus:border-gray-900"
                  >
                  <button
                    type="submit"
                    class="hidden h-12 w-12 items-center justify-center rounded-full border border-gray-300 bg-gray-50 text-sm text-gray-700 transition-colors duration-200 hover:bg-gray-100 hover:text-gray-900 sm:inline-flex"
                    aria-label="Buscar"
                  >
                    <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                  </button>
                </div>
              </form>

              <a href="/" class="text-sm font-semibold uppercase tracking-[0.08em] text-gray-900">
                Portada
              </a>
              <a
                href="/quienes-somos/"
                class="text-sm font-semibold uppercase tracking-[0.08em] {% if page.url == '/quienes-somos/' %}text-gray-900{% else %}text-gray-700 transition-colors duration-200 hover:text-gray-900{% endif %}"
              >
                Quiénes somos
              </a>

              {% if articulos and articulos.tags and articulos.tags.length %}
              <div class="border-t border-gray-200 pt-5 lg:hidden">
                <p class="text-sm font-semibold uppercase tracking-[0.08em] text-gray-500">Secciones</p>
                <div class="mt-4 flex flex-wrap gap-3">
                  {% for tag in articulos.tags %}
                  <a
                    href="/tema/{{ tag.slug }}/"
                    class="inline-flex min-h-11 items-center rounded-full border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-gray-700 transition-colors duration-200 hover:bg-gray-100 hover:text-gray-900"
                  >
                    {{ tag.name | themeName }}
                  </a>
                  {% endfor %}
                </div>
              </div>
              {% endif %}
            </div>
          </div>
        </div>
      </header>

      <section
        class="border-y border-[#DDD7CC] bg-[#F6F1E7] px-5 py-4 text-center sm:px-6 sm:py-[18px] lg:hidden"
        aria-label="Identidad editorial"
      >
        <div class="mx-auto flex max-w-7xl flex-col items-center">
          <span class="mb-2 h-px w-10 bg-[#B8AA8A]" aria-hidden="true"></span>
          <p class="font-['Montserrat',sans-serif] text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-[#5F5645] sm:text-[0.78rem] sm:tracking-[0.28em]">
            Información vecinal, útil e independiente sobre Valladolid
          </p>
        </div>
      </section>

      <main class="{% if page.url == '/' %}mt-0{% else %}mt-8 md:mt-10{% endif %}">
        {{ content | safe }}
      </main>

      <footer class="border-t border-gray-200 bg-white">
        <div class="mx-auto flex max-w-7xl flex-col gap-5 px-4 py-8 text-sm text-gray-600 {% if ogType == 'article' %}pb-28 md:pb-8{% endif %} sm:px-6 lg:px-8">
          <p>Proyecto comunitario e independiente sobre Valladolid</p>
          <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center sm:gap-4">
            <a
              href="{{ site.feedPath }}"
              class="inline-flex min-h-11 items-center gap-2 self-start rounded-full border border-gray-200 bg-white px-4 py-2 font-medium text-gray-800 transition-colors duration-200 hover:bg-gray-100 hover:text-gray-950"
            >
              <i class="fa-solid fa-rss text-[0.95rem] text-[#8A5A2B]" aria-hidden="true"></i>
              <span>RSS</span>
            </a>
            <a
              href="https://creativecommons.org/licenses/by-sa/4.0/deed.es"
              class="inline-flex min-h-11 items-center font-medium text-gray-800 transition-colors duration-200 hover:text-gray-950"
              target="_blank"
              rel="noreferrer"
            >
              Licencia CC BY-SA 4.0
            </a>
          </div>
        </div>
      </footer>
    </div>

    <script src="{{ assetManifest['assets/js/main.js'] or '/assets/js/main.js' }}" defer></script>
  </body>
</html>
