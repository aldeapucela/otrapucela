<div
  class="article-lightbox"
  data-article-lightbox
  hidden
  aria-hidden="true"
>
  <div
    class="article-lightbox__inner"
    role="dialog"
    aria-modal="true"
    aria-label="Imagen ampliada"
  >
    <div class="article-lightbox__frame">
      <button
        type="button"
        class="article-lightbox__close"
        data-article-lightbox-close
        aria-label="Cerrar imagen ampliada"
      >
        <i class="fa-solid fa-xmark" aria-hidden="true"></i>
      </button>
      <img class="article-lightbox__image" data-article-lightbox-image alt="">
    </div>
    <p class="article-lightbox__caption hidden" data-article-lightbox-caption></p>
  </div>
</div>
