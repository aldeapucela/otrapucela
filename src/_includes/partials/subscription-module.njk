{% set subscriptionVariant = subscriptionVariant or 'default' %}
{% set subscriptionTitle = subscriptionTitle or 'No te pierdas nada' %}
{% set subscriptionDescription = subscriptionDescription or 'Recibe nuevos artículos y resúmenes directamente en tu bandeja de entrada.' %}
{% set subscriptionButton = subscriptionButton or 'Ir al boletín' %}
{% set subscriptionSource = subscriptionSource or 'site-module' %}
{% set subscriptionHref = subscriptionHref or '/boletin/' %}
{% set subscriptionViewEvent = subscriptionViewEvent or '' %}
{% set subscriptionClickEvent = subscriptionClickEvent or '' %}
{% set subscriptionAnalyticsLocation = subscriptionAnalyticsLocation or subscriptionSource %}
{% set subscriptionAnalyticsVariant = subscriptionAnalyticsVariant or subscriptionVariant %}

<section class="subscription-module subscription-module--{{ subscriptionVariant }}{% if subscriptionArticleCard %} subscription-module--article-card{% endif %}" data-subscription-module data-newsletter-cta{% if subscriptionViewEvent %} data-analytics-view="{{ subscriptionViewEvent }}"{% endif %}{% if subscriptionAnalyticsLocation %} data-analytics-location="{{ subscriptionAnalyticsLocation }}"{% endif %}{% if subscriptionAnalyticsVariant %} data-analytics-variant="{{ subscriptionAnalyticsVariant }}"{% endif %}>
  {% if subscriptionEyebrow %}
  <p class="subscription-module__eyebrow">{{ subscriptionEyebrow }}</p>
  {% endif %}

  <div class="subscription-module__content">
    <div class="subscription-module__copy">
      <h2 class="subscription-module__title">{{ subscriptionTitle }}</h2>
      {% if subscriptionDescription %}
      <p class="subscription-module__description">{{ subscriptionDescription }}</p>
      {% endif %}
    </div>

    <a
      href="{{ subscriptionHref }}"
      class="subscription-module__button"
      data-subscription-link
      data-subscription-source="{{ subscriptionSource }}"
      {% if subscriptionClickEvent %}data-analytics-click="{{ subscriptionClickEvent }}"{% endif %}
      {% if subscriptionAnalyticsLocation %}data-analytics-location="{{ subscriptionAnalyticsLocation }}"{% endif %}
      {% if subscriptionAnalyticsVariant %}data-analytics-variant="{{ subscriptionAnalyticsVariant }}"{% endif %}
    >
      {{ subscriptionButton }}
    </a>
  </div>
</section>
