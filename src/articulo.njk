---
layout: base.njk
pagination:
  data: articulos.items
  size: 1
  alias: articulo
permalink: "/p/{{ articulo.id }}/{{ articulo.slug }}/index.html"
eleventyComputed:
  title: "{{ articulo.title }} - La Otra Pucela"
  description: "{{ articulo.description or 'Artículo publicado en Aldea Pucela.' }}"
  ogType: "article"
  ogTitle: "{{ articulo.title }} - La Otra Pucela"
  ogDescription: "{{ articulo.description or 'Artículo publicado en Aldea Pucela.' }}"
  ogImage: "{{ articulo.image or site.defaultSocialImage }}"
  canonicalUrl: "{{ articulo.publicPath }}"
---
{% set relatedItems = articulos.items | relatedArticles(articulo, 5) %}
{% set audioDownloadName = articulo.title ~ ' (' ~ articulo.author.name ~ ' - La Otra Pucela).mp3' %}
{% set articleDescription = articulo.description or articulo.excerpt or 'Artículo publicado en La Otra Pucela.' %}
{% set articleImage = (articulo.image or site.defaultSocialImage) | absoluteUrl(site.siteUrl) %}
{% set articleUrl = articulo.publicPath | absoluteUrl(site.siteUrl) %}
{% set authorUrl = articulo.author.publicPath | absoluteUrl(site.siteUrl) %}
{% set publisherLogo = '/assets/logo-wordmark.png' | absoluteUrl(site.siteUrl) %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  "headline": {{ articulo.title | json | safe }},
  "description": {{ articleDescription | json | safe }},
  "datePublished": "{{ articulo.createdAt }}",
  "dateModified": "{{ articulo.updatedAt or articulo.createdAt }}",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ articleUrl }}"
  },
  "url": "{{ articleUrl }}",
  "image": [
    "{{ articleImage }}"
  ],
  {% if articulo.tags and articulo.tags.length %}
  "articleSection": {{ articulo.tags[0].name | json | safe }},
  {% endif %}
  "author": {
    "@type": "Person",
    "name": {{ articulo.author.name | json | safe }},
    "url": "{{ authorUrl }}"
  },
  "publisher": {
    "@type": "Organization",
    "name": {{ site.name | json | safe }},
    "url": "{{ site.siteUrl }}",
    "logo": {
      "@type": "ImageObject",
      "url": "{{ publisherLogo }}"
    }
  }
}
</script>

<section class="mx-auto max-w-6xl px-4 pb-40 pt-8 sm:px-6 md:pb-28 lg:px-8 lg:pt-12">
  <article class="mx-auto mb-12 w-full max-w-6xl" data-article-id="{{ articulo.id }}">
    <div class="mx-auto max-w-4xl">
      <header class="border-b border-[#EEE] dark:border-gray-800 pb-8">
        {% if articulo.tags.length %}
        <div class="mb-4 flex flex-wrap gap-x-4 gap-y-2 text-xs font-semibold uppercase tracking-[0.08em] text-gray-500 dark:text-gray-400">
          {% if vinetaIds and vinetaIds.includes(articulo.id) %}
          <a
            href="{{ site.vinetaPath }}"
            class="transition-colors duration-200 hover:text-gray-900 dark:text-white"
          >
            La viñeta
          </a>
          {% endif %}
          {% for tag in articulo.tags %}
          <a
            href="/tema/{{ tag.slug }}/"
            class="transition-colors duration-200 hover:text-gray-900 dark:text-white"
          >
            {{ tag.name | themeName }}
          </a>
          {% endfor %}
        </div>
        {% endif %}

        <h1 class="font-serif text-[2rem] font-semibold leading-[1.02] tracking-tight text-gray-900 dark:text-white md:text-[3.2rem]">
          {{ articulo.title }}
        </h1>

        {% if articulo.description or articulo.excerpt %}
        <p class="mt-5 max-w-3xl text-[1.1rem] leading-[1.35] text-gray-600 dark:text-gray-400 md:text-[1.45rem] md:leading-[1.4]">
          {{ articulo.description or articulo.excerpt }}
        </p>
        {% endif %}

        <div class="mt-7">
          <div class="flex items-center gap-3 text-sm text-gray-600 dark:text-gray-400">
            {% if articulo.author.avatarUrl %}
            <img
              src="{{ articulo.author.avatarUrl }}"
              alt="{{ articulo.author.name }}"
              class="h-10 w-10 rounded-full object-cover"
              loading="lazy"
            >
            {% else %}
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-gray-200 text-sm font-semibold text-gray-700 dark:text-gray-300">
              {{ articulo.author.name[0] }}
            </div>
            {% endif %}
            <div class="min-w-0">
              <div class="text-base font-medium text-gray-900 dark:text-white">
                <a href="{{ articulo.author.publicPath }}" class="transition-colors duration-200 hover:text-gray-700 dark:text-gray-300">
                  {{ articulo.author.name }}
                </a>
              </div>
              <time datetime="{{ articulo.createdAt }}" class="mt-1 block text-sm text-gray-500 dark:text-gray-400">{{ articulo.createdAt | date("d MMMM yyyy") }}</time>
            </div>
          </div>

          <div class="mt-5 flex items-center gap-6 pl-[0.7rem] text-sm text-gray-700 dark:text-gray-300 sm:pl-[0.85rem]">
            {% if articulo.audio and articulo.audio.sources and articulo.audio.sources.length %}
            <button
              type="button"
              class="js-audio-start hidden min-h-11 items-center gap-2 font-medium transition-colors duration-200 hover:text-gray-900 dark:text-white md:inline-flex"
              data-audio-only
              aria-label="Escuchar artículo"
            >
              <i class="fa-solid fa-play w-4 text-center text-sm" aria-hidden="true"></i>
              <span>Escuchar</span>
            </button>
            {% endif %}
            <a
              href="#comentarios"
              class="inline-flex min-h-11 items-center gap-2 font-medium transition-colors duration-200 hover:text-gray-900 dark:text-white"
            >
              <i class="fa-regular fa-comment w-4 text-center text-sm" aria-hidden="true"></i>
              <span class="js-comment-count hidden" aria-live="polite"></span>
            </a>
            <button
              type="button"
              class="js-reading-list-toggle inline-flex min-h-11 items-center gap-2 font-medium transition-colors duration-200 hover:text-gray-900 dark:text-white"
              data-reading-list-toggle
              data-article-id="{{ articulo.id }}"
              data-article-title="{{ articulo.title }}"
              data-article-url="{{ articulo.publicPath }}"
              data-article-image="{{ articulo.image }}"
              data-article-author="{{ articulo.author.name }}"
              data-article-date="{{ articulo.createdAt }}"
              aria-pressed="false"
              aria-label="Guardar en lista de lectura"
            >
              <i class="fa-regular fa-bookmark js-reading-list-toggle-icon w-4 text-center text-sm" aria-hidden="true"></i>
              <span class="js-reading-list-toggle-label">Leer más tarde</span>
            </button>
            <button
              type="button"
              class="js-share-btn inline-flex min-h-11 items-center gap-2 font-medium transition-colors duration-200 hover:text-gray-900 dark:text-white"
              data-share-source="article-header"
              data-share-content-type="article"
              data-share-content-id="{{ articulo.id }}"
              data-url="{{ articulo.publicPath }}"
              data-title="{{ articulo.title }}"
              aria-label="Compartir artículo"
            >
              <i class="fa-solid fa-share-nodes js-share-btn-icon w-4 text-center text-sm" aria-hidden="true"></i>
              <span class="js-share-btn-label">Compartir</span>
            </button>
          </div>
        </div>

      </header>
    </div>

    {% if articulo.isVideo %}
    <div class="article-video-player mx-auto mt-10 w-full max-w-4xl">
      <div class="overflow-hidden rounded-[1.35rem] border border-[#E6DDCF] dark:border-gray-700 bg-gray-100 shadow-sm">
        <div class="article-video-player__frame relative w-full overflow-hidden">
          <iframe
            src="{{ articulo.mediaUrl }}"
            title="{{ articulo.title }}"
            class="article-video-player__iframe absolute inset-0 block h-full w-full border-0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
      </div>
    </div>
    {% endif %}

    {% if articulo.bodyHtml or articulo.contentHtml %}
    <div class="article-body {% if articulo.isVideo %}article-body--video {% endif %}prose dark:prose-invert prose-lg prose-gray mx-auto mt-10 w-full max-w-prose text-lg leading-relaxed text-gray-800 dark:text-gray-200 prose-headings:font-semibold prose-headings:tracking-tight prose-headings:text-gray-900 dark:prose-headings:text-white prose-p:my-5 prose-li:my-1 prose-img:my-6 prose-img:rounded-none prose-img:shadow-sm prose-hr:my-10 [&_.emoji]:my-0 [&_.emoji]:inline-block [&_.emoji]:h-[1.1em] [&_.emoji]:w-[1.1em] [&_.emoji]:align-[-0.15em] [&_.emoji]:rounded-none [&_.emoji]:shadow-none">
      {{ (articulo.bodyHtml or articulo.contentHtml) | safe }}
    </div>
    {% endif %}
  </article>

  <div class="mx-auto mb-10 hidden max-w-prose justify-end lg:flex">
    <button
      type="button"
      class="js-share-btn inline-flex min-h-11 items-center gap-2 rounded-full border border-gray-200 dark:border-gray-800 bg-white dark:bg-[#1a2529] px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 transition-colors duration-200 hover:bg-gray-100 dark:bg-gray-800 hover:text-gray-900 dark:text-white"
      data-share-source="article-inline"
      data-share-content-type="article"
      data-share-content-id="{{ articulo.id }}"
      data-url="{{ articulo.publicPath }}"
      data-title="{{ articulo.title }}"
      aria-label="Compartir artículo"
    >
      <i class="fa-solid fa-share-nodes js-share-btn-icon w-4 text-center text-sm" aria-hidden="true"></i>
      <span class="js-share-btn-label">Compartir</span>
    </button>
  </div>

  <div class="mx-auto max-w-prose">
    {% set subscriptionVariant = 'default' %}
    {% set subscriptionTitle = '¿Te gusta lo que lees?' %}
    {% set subscriptionDescription = 'Recibe gratis por correo los próximos artículos de La Otra Pucela, el único medio vecinal e independiente de la ciudad' %}
    {% set subscriptionButton = 'Apuntarme' %}
    {% set subscriptionSource = 'article-end' %}
    {% include "partials/subscription-module.njk" %}
  </div>

  {% if relatedItems.length %}
  <section class="mx-auto mt-16 max-w-6xl border-t border-[#EEE] dark:border-gray-800 pt-8">
    <div class="mb-6 flex items-center justify-between gap-4">
      <h2 class="text-2xl font-semibold tracking-tight text-gray-900 dark:text-white">Relacionados</h2>
      <div class="hidden items-center gap-3 lg:flex">
        <button
          type="button"
          class="js-related-prev inline-flex h-11 w-11 items-center justify-center rounded-full border border-gray-200 dark:border-gray-800 bg-white dark:bg-[#1a2529] text-gray-700 dark:text-gray-300 transition-colors duration-200 hover:bg-gray-100 dark:bg-gray-800 hover:text-gray-900 dark:text-white"
          aria-label="Ver relacionadas anteriores"
        >
          <i class="fa-solid fa-arrow-left text-sm" aria-hidden="true"></i>
        </button>
        <button
          type="button"
          class="js-related-next inline-flex h-11 w-11 items-center justify-center rounded-full border border-gray-200 dark:border-gray-800 bg-white dark:bg-[#1a2529] text-gray-700 dark:text-gray-300 transition-colors duration-200 hover:bg-gray-100 dark:bg-gray-800 hover:text-gray-900 dark:text-white"
          aria-label="Ver más relacionadas"
        >
          <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
        </button>
      </div>
    </div>

    <div class="js-related-viewport overflow-x-auto pb-2 [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden lg:max-w-[64rem]">
      <div class="js-related-track flex gap-5 lg:gap-4">
        {% for related in relatedItems %}
        <article class="w-[17.5rem] min-w-[17.5rem] border-r border-gray-200 dark:border-gray-800 pr-5 last:border-r-0 last:pr-0 sm:w-[19rem] sm:min-w-[19rem] lg:w-[14rem] lg:min-w-[14rem] lg:pr-4">
          <a href="{{ related.publicPath }}" class="block">
            {% if related.image %}
            <div class="mb-4 overflow-hidden bg-gray-100 dark:bg-gray-800">
              <img
                src="{{ related.image }}"
                alt="{{ related.title }}"
                class="aspect-[16/10] w-full object-cover"
                loading="lazy"
              >
            </div>
            {% endif %}

            <h3 class="font-serif text-[1.35rem] font-semibold leading-[1.08] tracking-tight text-gray-900 dark:text-white lg:text-[1.28rem]">
              {{ related.title }}
            </h3>

            {% if related.author and related.author.name %}
            <p class="mt-3 text-sm text-gray-700 dark:text-gray-300 lg:text-[0.95rem]">
              <a href="{{ related.author.publicPath }}" class="transition-colors duration-200 hover:text-gray-900 dark:text-white">
                {{ related.author.name }}
              </a>
            </p>
            {% endif %}
          </a>
        </article>
        {% endfor %}
      </div>
    </div>
  </section>
  {% endif %}

  <section
    class="js-most-read-section mx-auto mt-16 hidden max-w-6xl border-t border-[#EEE] pt-8 dark:border-gray-800"
    data-most-read-section
    data-current-article-path="{{ articulo.publicPath }}"
    aria-live="polite"
  >
    <div class="mb-6 flex items-center justify-between gap-4">
      <h2 class="text-2xl font-semibold tracking-tight text-gray-900 dark:text-white">Más leídas</h2>
      <div class="hidden items-center gap-3 lg:flex">
        <button
          type="button"
          class="js-carousel-prev inline-flex h-11 w-11 items-center justify-center rounded-full border border-gray-200 bg-white text-gray-700 transition-colors duration-200 hover:bg-gray-100 hover:text-gray-900 dark:border-gray-800 dark:bg-[#1a2529] dark:text-gray-300 dark:hover:bg-gray-800 dark:hover:text-white"
          data-carousel-prev
          aria-label="Ver historias anteriores de más leídas"
        >
          <i class="fa-solid fa-arrow-left text-sm" aria-hidden="true"></i>
        </button>
        <button
          type="button"
          class="js-carousel-next inline-flex h-11 w-11 items-center justify-center rounded-full border border-gray-200 bg-white text-gray-700 transition-colors duration-200 hover:bg-gray-100 hover:text-gray-900 dark:border-gray-800 dark:bg-[#1a2529] dark:text-gray-300 dark:hover:bg-gray-800 dark:hover:text-white"
          data-carousel-next
          aria-label="Ver más historias de más leídas"
        >
          <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
        </button>
      </div>
    </div>

    <div class="js-carousel-viewport overflow-x-auto pb-2 [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden lg:max-w-[64rem]" data-carousel-viewport>
      <div class="js-carousel-track flex gap-5 lg:gap-4" data-most-read-items data-carousel-track></div>
    </div>
  </section>

  <section
    class="js-conditional-subscription pointer-events-none fixed inset-x-0 bottom-0 z-50 px-3 pb-3 opacity-0 translate-y-6 md:inset-x-auto md:right-6 md:top-24 md:bottom-auto md:w-[24rem] md:px-0 md:pb-0 md:translate-y-0 lg:right-8"
    data-conditional-subscription
    data-newsletter-cta
    data-article-scroll-root
    aria-hidden="true"
  >
    <div class="mx-auto max-w-prose rounded-[1.75rem] bg-[#F4F1E9] dark:bg-gray-800 shadow-[0_10px_30px_rgba(0,0,0,0.1)]">
      <div class="flex items-start gap-4 px-5 pb-5 pt-6">
        <div class="min-w-0 flex-1">
          <p class="font-['Montserrat',sans-serif] text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-[#6B6253] dark:text-gray-400 dark:text-gray-500">Boletín</p>
          <p class="mt-2 pr-2 text-left text-[1rem] leading-[1.45] text-[#1F2937] dark:text-white sm:text-[1.0625rem]">
            ¡Gracias por volver!<br>
            ¿Te avisamos de lo nuevo?
          </p>
        </div>
        <button
          type="button"
          class="js-conditional-subscription-close inline-flex min-h-[3.25rem] min-w-[3.25rem] shrink-0 items-center justify-center rounded-full p-[0.95rem] text-[#6B6253] dark:text-gray-400 dark:text-gray-500 transition-colors duration-200 hover:bg-[#EAE3D7] hover:text-[#1F2937] dark:text-white"
          data-conditional-subscription-close
          aria-label="Cerrar suscripción"
        >
          <i class="fa-solid fa-xmark text-base" aria-hidden="true"></i>
        </button>
      </div>
      <div class="mb-4 px-5 pb-5">
        <a
          href="/boletin/"
          class="inline-flex min-h-12 w-full items-center justify-center rounded-full bg-black px-5 py-3 text-sm font-semibold uppercase tracking-[0.08em] text-white transition-colors duration-200 hover:bg-[#1A1A1A]"
          data-subscription-link
          data-subscription-source="article-conditional-slideup"
        >
          Sí, avisadme
        </a>
      </div>
    </div>
  </section>

  <button
    type="button"
    class="reading-resume-pill hidden"
    data-reading-resume-link
    aria-hidden="true"
  >
    Volver donde lo dejaste
  </button>

  <div class="article-mobile-sticky fixed bottom-0 z-40 border-t border-gray-200 dark:border-gray-800 bg-white dark:bg-[#1a2529]{% if not (articulo.audio and articulo.audio.sources and articulo.audio.sources.length) %} md:hidden{% endif %}" data-mobile-article-bar>
    <div class="article-mobile-sticky__inner mx-auto flex max-w-prose items-center gap-3">
      {% if articulo.audio and articulo.audio.sources and articulo.audio.sources.length %}
      <audio
        id="article-audio-element"
        class="js-article-audio sr-only"
        preload="none"
        data-article-id="{{ articulo.id }}"
        data-article-title="{{ articulo.title }}"
        data-article-author="{{ articulo.author.name }}"
        data-article-url="{{ articulo.publicPath }}"
      >
        {% for source in articulo.audio.sources %}
        <source data-src="{{ source.src }}" type="{{ source.type }}">
        {% endfor %}
        Tu navegador no puede reproducir este audio.
      </audio>
      <div class="article-mobile-sticky__player hidden" data-mobile-audio-player data-audio-only>
        <button
          type="button"
          class="article-mobile-sticky__collapse-handle js-audio-collapse"
          aria-label="Minimizar reproductor"
        >
          <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
        </button>
        <div class="article-mobile-sticky__meta" data-audio-drag-handle>
          <div class="article-mobile-sticky__title-marquee">
            <p class="article-mobile-sticky__title">
              <span class="article-mobile-sticky__title-text">{{ articulo.title }}</span>
              <span class="article-mobile-sticky__title-separator" aria-hidden="true"> • </span>
              <span class="article-mobile-sticky__title-text" aria-hidden="true">{{ articulo.title }}</span>
            </p>
          </div>
          <p class="article-mobile-sticky__byline">{{ articulo.author.name }}</p>
        </div>
        <div class="article-mobile-sticky__seek-wrap">
          <span class="article-mobile-sticky__time article-mobile-sticky__time--start js-audio-time-current" aria-live="off">0:00</span>
          <input
            type="range"
            class="article-mobile-sticky__seek js-audio-seek"
            min="0"
            max="100"
            value="0"
            step="0.1"
            aria-label="Barra de progreso del audio"
          >
          <span class="article-mobile-sticky__time article-mobile-sticky__time--end js-audio-time-duration" aria-live="off">0:00</span>
        </div>
        <div class="article-mobile-sticky__player-row">
          <div class="article-mobile-sticky__side-actions">
            <button
              type="button"
              class="js-share-btn article-mobile-sticky__action"
              data-share-source="article-mobile-sticky-player"
              data-share-content-type="article"
              data-share-content-id="{{ articulo.id }}"
              data-url="{{ articulo.publicPath }}"
              data-title="{{ articulo.title }}"
              aria-label="Compartir artículo"
            >
              <i class="fa-solid fa-share-nodes js-share-btn-icon text-base" aria-hidden="true"></i>
              <span class="sr-only js-share-btn-label">Compartir</span>
            </button>
            <a
              href="#comentarios"
              class="article-mobile-sticky__action"
              aria-label="Ir a comentarios"
            >
              <i class="fa-regular fa-comment text-base" aria-hidden="true"></i>
              <span class="js-comment-count article-mobile-sticky__count hidden" aria-live="polite"></span>
            </a>
          </div>
          <div class="article-mobile-sticky__audio-controls">
            <button
              type="button"
              class="article-mobile-sticky__control js-audio-skip-back"
              data-skip-seconds="-10"
              aria-label="Retroceder 10 segundos"
            >
              <i class="fa-solid fa-rotate-left" aria-hidden="true"></i>
              <span class="article-mobile-sticky__control-label">10</span>
            </button>
            <button
              type="button"
              class="article-mobile-sticky__play js-audio-play-toggle"
              aria-label="Reproducir artículo"
              data-audio-state="paused"
            >
              <i class="fa-solid fa-play js-audio-play-icon" aria-hidden="true"></i>
            </button>
            <button
              type="button"
              class="article-mobile-sticky__control js-audio-skip-forward"
              data-skip-seconds="10"
              aria-label="Avanzar 10 segundos"
            >
              <i class="fa-solid fa-rotate-right" aria-hidden="true"></i>
              <span class="article-mobile-sticky__control-label">10</span>
            </button>
          </div>
          <div class="article-mobile-sticky__right-actions">
            <div class="article-mobile-sticky__speed-wrap">
              <button
                type="button"
                class="article-mobile-sticky__speed-button js-audio-speed-toggle"
                aria-label="Cambiar velocidad de reproducción"
                aria-expanded="false"
              >
                <span class="js-audio-speed-label">1x</span>
              </button>
              <div class="article-mobile-sticky__speed-menu hidden" data-audio-speed-menu>
                <button type="button" class="article-mobile-sticky__speed-option js-audio-speed-option" data-speed="0.9">0.9x</button>
                <button type="button" class="article-mobile-sticky__speed-option js-audio-speed-option" data-speed="1">1x</button>
                <button type="button" class="article-mobile-sticky__speed-option js-audio-speed-option" data-speed="1.1">1.1x</button>
                <button type="button" class="article-mobile-sticky__speed-option js-audio-speed-option" data-speed="1.2">1.2x</button>
                <button type="button" class="article-mobile-sticky__speed-option js-audio-speed-option" data-speed="1.5">1.5x</button>
                <button type="button" class="article-mobile-sticky__speed-option js-audio-speed-option" data-speed="2">2x</button>
              </div>
            </div>
            <a
              href="{{ articulo.audio.downloadUrl }}"
              class="article-mobile-sticky__action js-audio-download"
              download="{{ audioDownloadName }}"
              aria-label="Descargar audio"
            >
              <i class="fa-regular fa-circle-down text-base" aria-hidden="true"></i>
            </a>
          </div>
        </div>
      </div>
      {% endif %}
      <div class="article-mobile-sticky__actions md:hidden" data-mobile-default-actions>
      {% if articulo.audio and articulo.audio.sources and articulo.audio.sources.length %}
      <button
        type="button"
        class="article-mobile-sticky__play-entry js-audio-start"
        data-audio-only
        aria-controls="article-audio-element"
        aria-label="Reproducir artículo"
      >
        <i class="fa-solid fa-play text-sm" aria-hidden="true"></i>
      </button>
      {% endif %}
      <a
        href="#comentarios"
        class="article-mobile-sticky__comment-link"
        aria-label="Ir a comentarios"
      >
        <i class="fa-regular fa-comment text-base" aria-hidden="true"></i>
        <span class="{% if articulo.audio and articulo.audio.sources and articulo.audio.sources.length %}hidden {% endif %}" data-no-audio-label>Comentar</span>
        <span class="js-comment-count article-mobile-sticky__count hidden" aria-live="polite"></span>
      </a>
      <button
        type="button"
        class="js-share-btn article-mobile-sticky__share"
        data-share-source="article-mobile-sticky"
        data-share-content-type="article"
        data-share-content-id="{{ articulo.id }}"
        data-url="{{ articulo.publicPath }}"
        data-title="{{ articulo.title }}"
        aria-label="Compartir artículo"
      >
        <i class="fa-solid fa-share-nodes js-share-btn-icon text-base" aria-hidden="true"></i>
        <span class="js-share-btn-label">Compartir</span>
      </button>
      </div>
    </div>
  </div>

  <div class="js-floating-actions fixed bottom-24 right-4 z-40 flex flex-col gap-3 lg:top-1/2 lg:-translate-y-1/2 lg:bottom-auto lg:right-[max(1.5rem,calc(50vw-32rem-4.5rem))]">
    <button
      type="button"
      class="js-scroll-top pointer-events-none inline-flex h-12 w-12 translate-y-3 items-center justify-center rounded-full border border-gray-200 dark:border-gray-800 bg-white dark:bg-[#1a2529]/95 text-gray-800 dark:text-gray-200 opacity-0 shadow-md backdrop-blur-sm transition-all duration-200 hover:bg-white dark:bg-[#1a2529] hover:text-gray-950"
      aria-label="Volver arriba"
      title="Volver arriba"
    >
      <i class="fa-solid fa-arrow-up text-sm" aria-hidden="true"></i>
    </button>
    <button
      type="button"
      class="js-scroll-theme-toggle js-theme-toggle pointer-events-none inline-flex h-12 w-12 translate-y-3 items-center justify-center rounded-full border border-gray-200 dark:border-gray-800 bg-white dark:bg-[#1a2529]/95 text-gray-800 dark:text-gray-200 opacity-0 shadow-md backdrop-blur-sm transition-all duration-200 hover:bg-white dark:bg-[#1a2529] hover:text-gray-950"
      aria-label="Cambiar tema"
      title="Cambiar tema"
    >
      <i class="js-theme-toggle-icon fa-solid fa-moon text-[0.92rem]" aria-hidden="true"></i>
    </button>
    <button
      type="button"
      class="js-scroll-share-btn js-share-btn pointer-events-none hidden h-12 w-12 translate-y-3 items-center justify-center rounded-full border border-gray-200 dark:border-gray-800 bg-white dark:bg-[#1a2529]/95 text-gray-800 dark:text-gray-200 opacity-0 shadow-md backdrop-blur-sm transition-all duration-200 hover:bg-white dark:bg-[#1a2529] hover:text-gray-950 md:inline-flex"
      data-share-source="article-desktop-floating"
      data-share-content-type="article"
      data-share-content-id="{{ articulo.id }}"
      data-url="{{ articulo.publicPath }}"
      data-title="{{ articulo.title }}"
      aria-label="Compartir artículo"
    >
      <i class="fa-solid fa-share-nodes js-share-btn-icon text-sm" aria-hidden="true"></i>
      <span class="sr-only js-share-btn-label">Compartir</span>
    </button>
  </div>

  <section
    id="comentarios"
    class="js-comments-root -mx-4 mt-16 w-auto overflow-x-clip border-t border-gray-200 dark:border-gray-800 bg-white dark:bg-[#1a2529] px-4 py-8 sm:-mx-6 sm:px-6 lg:-mx-8 lg:px-8"
    data-discourse-url="https://foro.aldeapucela.org/"
    data-topic-id="{{ articulo.id }}"
    data-topic-url="{{ articulo.discourseTopicUrl }}"
    data-topic-json-url="{{ articulo.source.topicJsonUrl }}"
    data-initial-replies="0"
  >
    <div class="mx-auto w-full max-w-prose">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div class="w-full text-left">
          <h2 class="text-2xl font-semibold tracking-tight text-gray-900 dark:text-white uppercase">Comentarios</h2>
          <p class="mt-0 text-xs leading-[1.6] text-gray-400 dark:text-gray-400">con tecnología de Aldea Pucela</p>
        </div>
        <a
          href="{{ articulo.discourseTopicUrl }}/2"
          class="js-add-comment-link{% if articulo.replies == 0 %} hidden{% endif %} inline-flex min-h-11 items-center justify-center self-center rounded-full border border-gray-200 dark:border-gray-800 bg-gray-900 px-4 py-2 text-xs font-semibold text-white transition-colors duration-200 hover:bg-gray-700 sm:self-auto"
          target="_blank"
          rel="noreferrer"
        >
          Añadir comentario
        </a>
      </div>

      <div class="js-comments-embed-wrapper hidden mt-10 overflow-hidden rounded-2xl bg-white p-4 shadow-sm ring-1 ring-gray-200 dark:ring-gray-700 sm:p-8">
        <div id="discourse-comments" class="js-comments-embed bg-white"></div>
      </div>

      <div class="js-comments-empty-state{% if articulo.replies > 0 %} hidden{% endif %} mt-6 bg-white dark:bg-[#1a2529] text-left">
        <p class="text-xl font-semibold text-gray-700 dark:text-gray-300">¿Qué piensas de este artículo?</p>
        <p class="mt-2 leading-relaxed text-gray-600 dark:text-gray-400">
          Sé la primera persona en comentar y comparte tu punto de vista en el foro.
        </p>
        <a
          href="{{ articulo.discourseTopicUrl }}/2"
          class="mx-auto mt-5 inline-flex min-h-11 items-center justify-center rounded-full bg-gray-900 px-6 py-3 text-sm font-semibold text-white transition-colors duration-200 hover:bg-gray-700"
          target="_blank"
          rel="noreferrer"
        >
          Añadir un comentario
        </a>
      </div>
    </div>
  </section>
</section>
