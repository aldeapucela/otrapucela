---
permalink: /vineta/feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:content="http://purl.org/rss/1.0/modules/content/" xmlns:media="http://search.yahoo.com/mrss/">
  <channel>
    <title>{{ site.vineta.title | escape }}</title>
    <link>{{ site.siteUrl }}{{ site.vinetaPath }}</link>
    <description>{{ site.vineta.description | escape }}</description>
    <language>es-ES</language>
    <lastBuildDate>{{ vineta.generatedAt | date("rfc2822") }}</lastBuildDate>
    <atom:link href="{{ site.siteUrl }}{{ site.vinetaFeedPath }}" rel="self" type="application/rss+xml" />
    {% for pieza in vineta.items %}
    {% set pieceImageUrl = pieza.image %}
    {% if pieceImageUrl and pieceImageUrl[0] == "/" %}
    {% set pieceImageUrl = site.siteUrl + pieceImageUrl %}
    {% endif %}
    <item>
      <title>{{ pieza.title | escape }}</title>
      <link>{{ site.siteUrl }}{{ pieza.publicPath }}</link>
      <guid isPermaLink="true">{{ site.siteUrl }}{{ pieza.publicPath }}</guid>
      <pubDate>{{ pieza.createdAt | date("rfc2822") }}</pubDate>
      {% if pieceImageUrl %}
      <enclosure url="{{ pieceImageUrl | escape }}" type="image/*" />
      <media:content url="{{ pieceImageUrl | escape }}" medium="image" />
      <media:thumbnail url="{{ pieceImageUrl | escape }}" />
      {% endif %}
      <description><![CDATA[{{ pieza.description | escape }}]]></description>
      <content:encoded><![CDATA[{{ pieza.contentHtml | safe }}]]></content:encoded>
      {% if pieza.author and pieza.author.name %}
      <author>{{ pieza.author.name | escape }}</author>
      {% endif %}
      {% for tag in pieza.tags %}
      <category>{{ tag.name | themeName | escape }}</category>
      {% endfor %}
    </item>
    {% endfor %}
  </channel>
</rss>
