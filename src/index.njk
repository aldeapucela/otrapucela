---
layout: base.njk
title: La Otra Pucela - Información vecinal, útil e independiente sobre Valladolid
description: Información vecinal, útil e independiente sobre Valladolid.
ogTitle: La Otra Pucela - Información vecinal, útil e independiente sobre Valladolid
ogDescription: Información vecinal, útil e independiente sobre Valladolid.
canonicalUrl: /
---
<section class="mx-auto max-w-7xl px-4 pt-4 pb-8 sm:px-6 lg:px-8 lg:pt-4 lg:pb-10">
  <div class="hidden lg:block">
    <div class="py-2 text-center">
      <a href="/" class="inline-block font-serif text-4xl font-extrabold uppercase tracking-[0.03em] text-gray-900">
        La Otra Pucela
      </a>
      <p class="mx-auto mt-2 max-w-2xl text-center text-base leading-relaxed text-gray-600">
        Información vecinal, útil e independiente sobre Valladolid
      </p>
    </div>
  </div>

  <div class="mt-10 grid grid-cols-1 gap-x-10 gap-y-12 lg:hidden">
    {% for articulo in articulos.items %}
    <article class="border-b border-gray-200 pb-10 last:border-b-0 last:pb-0">
      <a href="/p/{{ articulo.id }}/{{ articulo.slug }}/" class="block">
        {% if articulo.image %}
        <div class="mb-6 overflow-hidden bg-gray-100">
          <img
            src="{{ articulo.image }}"
            alt="{{ articulo.title }}"
            class="aspect-[16/10] w-full object-cover"
            loading="lazy"
          >
        </div>
        {% else %}
        {% endif %}

        <div class="max-w-3xl">
          <div class="flex items-center gap-2 text-sm text-gray-500">
            <time datetime="{{ articulo.createdAt }}">{{ articulo.createdAt | date("d MMM yyyy") }}</time>
          </div>

          <h2 class="mt-4 font-serif text-2xl font-semibold leading-[1.08] tracking-tight text-gray-900 sm:text-[2rem]">
            {{ articulo.title }}
          </h2>

          {% if articulo.description %}
          <p class="mt-4 text-[0.98rem] leading-[1.55] text-gray-600 sm:text-[1.04rem]">
            {{ articulo.description }}
          </p>
          {% elif articulo.excerpt %}
          <p class="mt-4 text-[0.98rem] leading-[1.55] text-gray-600 sm:text-[1.04rem]">
            {{ articulo.excerpt }}
          </p>
          {% endif %}

          {% if articulo.author and articulo.author.name %}
          <p class="mt-5 text-sm font-normal text-gray-400">
            <a href="{{ articulo.author.publicPath }}" class="transition-colors duration-200 hover:text-gray-700">
              {{ articulo.author.name }}
            </a>
          </p>
          {% endif %}

          {% if articulo.tags.length %}
          <div class="mt-5 flex flex-wrap gap-2">
            {% for tag in articulo.tags %}
            <a
              href="/tema/{{ tag.slug }}/"
              class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-700 transition-colors duration-200 hover:bg-gray-200 hover:text-gray-900"
            >
              {{ tag.name | themeName }}
            </a>
            {% endfor %}
          </div>
          {% endif %}
        </div>
      </a>
    </article>
    {% endfor %}
  </div>

  <div class="mt-4 hidden border-t border-gray-300 pt-6 lg:grid lg:grid-cols-3 lg:gap-6">
    {% for articulo in articulos.items %}
    <article class="border-b border-gray-200 pb-8">
      <a href="/p/{{ articulo.id }}/{{ articulo.slug }}/" class="block">
        {% if articulo.image %}
        <div class="mb-4 overflow-hidden bg-gray-100">
          <img
            src="{{ articulo.image }}"
            alt="{{ articulo.title }}"
            class="aspect-[16/10] w-full object-cover"
            loading="lazy"
          >
        </div>
        {% endif %}

        <div class="flex items-center gap-2 text-sm text-gray-500">
          <time datetime="{{ articulo.createdAt }}">{{ articulo.createdAt | date("d MMM yyyy") }}</time>
        </div>

        <h2 class="mt-4 font-serif text-[1.55rem] font-semibold leading-[1.08] tracking-tight text-gray-900">
          {{ articulo.title }}
        </h2>

        {% if articulo.description %}
        <p class="mt-3 text-[0.95rem] leading-[1.55] text-gray-600">
          {{ articulo.description }}
        </p>
        {% elif articulo.excerpt %}
        <p class="mt-3 text-[0.95rem] leading-[1.55] text-gray-600">
          {{ articulo.excerpt }}
        </p>
        {% endif %}

        {% if articulo.author and articulo.author.name %}
        <p class="mt-4 text-sm text-gray-500">
          <a href="{{ articulo.author.publicPath }}" class="transition-colors duration-200 hover:text-gray-700">
            {{ articulo.author.name }}
          </a>
        </p>
        {% endif %}

        {% if articulo.tags.length %}
        <div class="mt-4 flex flex-wrap gap-2">
          {% for tag in articulo.tags %}
          <a
            href="/tema/{{ tag.slug }}/"
            class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-700 transition-colors duration-200 hover:bg-gray-200 hover:text-gray-900"
          >
            {{ tag.name | themeName }}
          </a>
          {% endfor %}
        </div>
        {% endif %}
      </a>
    </article>
      {% if loop.index % 3 == 0 and not loop.last %}
  </div>
  <div class="mt-10 hidden border-t border-gray-200 pt-8 lg:grid lg:grid-cols-3 lg:gap-6">
      {% endif %}
    {% endfor %}
  </div>
</section>
