---
layout: base.njk
pagination:
  data: articulos.tags
  size: 1
  alias: tag
permalink: "/tema/{{ tag.slug }}/index.html"
eleventyComputed:
  title: "{{ tag.name | themeName }} - La Otra Pucela"
  description: "Artículos del tema {{ tag.name | themeName }}."
  ogTitle: "{{ tag.name | themeName }} - La Otra Pucela"
  ogDescription: "Artículos del tema {{ tag.name | themeName }}."
  canonicalUrl: "/tema/{{ tag.slug }}/"
---
{% set themeArticles = articulos.items | articlesForTheme(tag.slug) %}
<section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8 lg:py-12">
  <div class="max-w-3xl">
    <h1 class="text-[2rem] font-extrabold uppercase tracking-tight text-gray-900 dark:text-white sm:text-[2.5rem]">
      {{ tag.name | themeName }}
    </h1>
    <div class="mt-6 h-px w-full max-w-6xl bg-gray-900"></div>
  </div>

  <div class="mt-10 grid grid-cols-1 gap-x-10 gap-y-12 lg:hidden">
    {% for articulo in themeArticles %}
    <article class="border-b border-gray-200 dark:border-gray-800 pb-10 last:border-b-0 last:pb-0">
      <a href="/p/{{ articulo.id }}/{{ articulo.slug }}/" class="block">
        {% set articleImage = articulo.previewImage or articulo.image %}
        {% if articleImage %}
        <div class="mb-6 overflow-hidden bg-gray-100 dark:bg-gray-800">
          <img
            src="{{ articleImage }}"
            alt="{{ articulo.title }}"
            class="aspect-[16/10] w-full object-cover"
            loading="lazy"
          >
        </div>
        {% endif %}

        <div class="max-w-3xl">
          <div class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
            <time datetime="{{ articulo.createdAt }}">{{ articulo.createdAt | date("d MMM yyyy") }}</time>
          </div>

          <h2 class="mt-4 font-serif text-2xl font-semibold leading-[1.08] tracking-tight text-gray-900 dark:text-white sm:text-[2rem]">
            {{ articulo.title }}
          </h2>

          {% if articulo.description %}
          <p class="mt-4 text-lg leading-[1.35] text-gray-600 dark:text-gray-400 sm:text-xl">
            {{ articulo.description }}
          </p>
          {% elif articulo.excerpt %}
          <p class="mt-4 text-lg leading-[1.35] text-gray-600 dark:text-gray-400 sm:text-xl">
            {{ articulo.excerpt }}
          </p>
          {% endif %}

          {% if articulo.author and articulo.author.name %}
          <p class="mt-5 text-sm font-normal text-gray-400 dark:text-gray-400">
            <a href="{{ articulo.author.publicPath }}" class="transition-colors duration-200 hover:text-gray-700 dark:text-gray-300">
              {{ articulo.author.name }}
            </a>
          </p>
          {% endif %}
        </div>
      </a>
    </article>
    {% endfor %}
  </div>

  {% set featuredArticle = themeArticles[0] %}
  {% if featuredArticle %}
  <div class="mt-12 hidden border-t border-gray-300 dark:border-gray-600 pt-6 lg:grid lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1.75fr)] lg:items-start lg:gap-8">
    <article class="pr-2">
      <a href="/p/{{ featuredArticle.id }}/{{ featuredArticle.slug }}/" class="block">
        <h2 class="font-serif text-[2.15rem] font-semibold leading-[1.02] tracking-tight text-gray-900 dark:text-white">
          {{ featuredArticle.title }}
        </h2>

        {% if featuredArticle.description %}
        <p class="mt-4 text-[1.05rem] leading-[1.45] text-gray-600 dark:text-gray-400">
          {{ featuredArticle.description }}
        </p>
        {% elif featuredArticle.excerpt %}
        <p class="mt-4 text-[1.05rem] leading-[1.45] text-gray-600 dark:text-gray-400">
          {{ featuredArticle.excerpt }}
        </p>
        {% endif %}

        {% if featuredArticle.author and featuredArticle.author.name %}
        <p class="mt-4 text-base text-gray-500 dark:text-gray-400">
          <a href="{{ featuredArticle.author.publicPath }}" class="transition-colors duration-200 hover:text-gray-700 dark:text-gray-300">
            {{ featuredArticle.author.name }}
          </a>
        </p>
        {% endif %}
      </a>
    </article>

    <article>
      <a href="/p/{{ featuredArticle.id }}/{{ featuredArticle.slug }}/" class="block">
        {% set featuredArticleImage = featuredArticle.previewImage or featuredArticle.image %}
        {% if featuredArticleImage %}
        <div class="overflow-hidden bg-gray-100 dark:bg-gray-800">
          <img
            src="{{ featuredArticleImage }}"
            alt="{{ featuredArticle.title }}"
            class="aspect-[21/9] max-h-[25rem] w-full object-cover"
            loading="lazy"
          >
        </div>
        {% endif %}
      </a>
    </article>
  </div>

  <div class="mt-10 hidden border-t border-gray-200 dark:border-gray-800 pt-8 lg:grid lg:grid-cols-3 lg:gap-6">
    {% for articulo in themeArticles.slice(1) %}
    <article class="border-b border-gray-200 dark:border-gray-800 pb-8">
      <a href="/p/{{ articulo.id }}/{{ articulo.slug }}/" class="block">
        {% set articleImage = articulo.previewImage or articulo.image %}
        {% if articleImage %}
        <div class="mb-4 overflow-hidden bg-gray-100 dark:bg-gray-800">
          <img
            src="{{ articleImage }}"
            alt="{{ articulo.title }}"
            class="aspect-[16/10] w-full object-cover"
            loading="lazy"
          >
        </div>
        {% endif %}

        <h2 class="font-serif text-[1.4rem] font-semibold leading-[1.08] tracking-tight text-gray-900 dark:text-white">
          {{ articulo.title }}
        </h2>

        {% if articulo.author and articulo.author.name %}
        <p class="mt-4 text-sm text-gray-500 dark:text-gray-400">
          <a href="{{ articulo.author.publicPath }}" class="transition-colors duration-200 hover:text-gray-700 dark:text-gray-300">
            {{ articulo.author.name }}
          </a>
        </p>
        {% endif %}
      </a>
    </article>
      {% if loop.index % 3 == 0 and not loop.last %}
  </div>
  <div class="mt-10 hidden border-t border-gray-200 dark:border-gray-800 pt-8 lg:grid lg:grid-cols-3 lg:gap-6">
      {% endif %}
    {% endfor %}
  </div>
  {% endif %}
</section>
