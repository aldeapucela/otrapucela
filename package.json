{
  "name": "otrapucela",
  "version": "0.1.0",
  "private": true,
  "description": "Medio digital estatico con Eleventy y datos de Discourse",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build:css": "tailwindcss -c tailwind.config.js -i ./src/assets/styles/main.css -o ./dist/assets/styles/main.css --minify",
    "build:assets": "node ./scripts/rev-assets.mjs",
    "build": "npm run clean && npm run build:css && npm run build:assets && eleventy",
    "start": "eleventy --serve --port=8000"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.0.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "cheerio": "^1.2.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.17"
  }
}
